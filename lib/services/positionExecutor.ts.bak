/**
 * Position Executor Service
 * Handles position execution logic with paper/live trading mode support
 * Routes to simulated or real OANDA execution based on is_paper_trading flag
 *
 * @requires OANDAService implementation for live mode (Phase 4+)
 * @requires process.env.OANDA_API_KEY for live trading
 * @requires process.env.OANDA_ACCOUNT_ID for live trading
 */

import { createClient } from '@/lib/supabase/server'
import type { SupabaseClient } from '@supabase/supabase-js'
import type { Database } from '@/types/database'

interface ExecutionResult {
  success: boolean
  execution_type: 'simulated' | 'live'
  message: string
  order_id?: string
}

/**
 * Execute a position entry at the specified price
 * Checks is_paper_trading flag and routes to appropriate execution method
 */
export async function executePositionEntry(
  positionId: string,
  entryPrice: number,
  oandaOrderData?: any
): Promise<ExecutionResult> {
  try {
    const supabase = await createClient()

    // Fetch position with is_paper_trading flag
    const { data: position, error: positionError } = await supabase
      .from('positions')
      .select('*')
      .eq('id', positionId)
      .single()

    if (positionError || !position) {
      return {
        success: false,
        execution_type: 'simulated',
        message: 'Position not found'
      }
    }

    const isPaperTrading = position.is_paper_trading

    if (isPaperTrading) {
      // Simulate execution - no real OANDA call
      return simulatePositionExecution(positionId, entryPrice, supabase)
    } else {
      // Live execution - call OANDA API
      return livePositionExecution(positionId, entryPrice, oandaOrderData, supabase)
    }
  } catch (error) {
    console.error('[Position Executor] Error executing position:', error)
    return {
      success: false,
      execution_type: 'simulated',
      message: 'Execution failed: ' + (error instanceof Error ? error.message : 'Unknown error')
    }
  }
}

/**
 * Update position with entry price and open status
 * @internal
 */
async function updatePositionEntry(
  supabase: SupabaseClient<Database>,
  positionId: string,
  entryPrice: number
): Promise<boolean> {
  const { error } = await supabase
    .from('positions')
    .update({
      entry_price: entryPrice,
      status: 'open'
    } as any)
    .eq('id', positionId)

  return !error
}

/**
 * Log execution event to monitoring_events table
 * @internal
 */
async function logExecutionEvent(
  supabase: SupabaseClient<Database>,
  positionId: string,
  eventType: string,
  price: number,
  description: string
): Promise<void> {
  const { error } = await supabase
    .from('monitoring_events')
    .insert({
      position_id: positionId,
      event_type: eventType as any,
      price,
      description
    })

  if (error) {
    console.error('[Position Executor] Failed to log event:', error)
  }
}

/**
 * Simulate position execution (paper trading mode)
 * Records execution in database without calling OANDA
 */
async function simulatePositionExecution(
  positionId: string,
  entryPrice: number,
  supabase: SupabaseClient<Database>
): Promise<ExecutionResult> {
  try {
    // Update position with entry price
    const success = await updatePositionEntry(supabase, positionId, entryPrice)
    if (!success) {
      throw new Error('Failed to update position')
    }

    // Log simulated execution to monitoring_events
    await logExecutionEvent(
      supabase,
      positionId,
      'simulated_execution',
      entryPrice,
      `PAPER MODE: Simulated entry at $${entryPrice}`
    )

    return {
      success: true,
      execution_type: 'simulated',
      message: `Paper trading: simulated entry at $${entryPrice}`
    }
  } catch (error) {
    console.error('[Position Executor] Simulation error:', error)
    return {
      success: false,
      execution_type: 'simulated',
      message: 'Simulation failed: ' + (error instanceof Error ? error.message : 'Unknown error')
    }
  }
}

