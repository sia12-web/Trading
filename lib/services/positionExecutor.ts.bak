/**
 * Close a position at specified price
 * Routes to simulated or live exit based on is_paper_trading flag
 */
export async function closePositionExit(
  positionId: string,
  exitPrice: number
): Promise<ExecutionResult> {
  try {
    const supabase = await createClient()

    // Fetch position
    const { data: position, error: positionError } = await supabase
      .from('positions')
      .select('*')
      .eq('id', positionId)
      .single()

    if (positionError || !position) {
      return {
        success: false,
        execution_type: 'simulated',
        message: 'Position not found'
      }
    }

    const isPaperTrading = position.is_paper_trading
    const exitType = isPaperTrading ? 'simulated_close' : 'live_close'

    // Both paper and live use same exit logic - flag is for entry only
    // Exit is triggered by reaching SL/TP regardless of mode
    const result = await executePositionExit(
      positionId,
      exitPrice,
      exitType,
      supabase
    )

    return result
  } catch (error) {
    console.error('[Position Executor] Error closing position:', error)
    return {
      success: false,
      execution_type: 'simulated',
      message: 'Close failed: ' + (error instanceof Error ? error.message : 'Unknown error')
    }
  }
}

/**
 * Execute position exit (applies to both paper and live)
 * @internal
 */
async function executePositionExit(
  positionId: string,
  exitPrice: number,
  exitType: string,
  supabase: SupabaseClient<Database>
): Promise<ExecutionResult> {
  try {
    // Update position with exit price and close status
    const { error: updateError } = await supabase
      .from('positions')
      .update({
        exit_price: exitPrice,
        status: 'closed',
        closed_at: new Date().toISOString()
      })
      .eq('id', positionId)

    if (updateError) {
      throw updateError
    }

    // Log close to monitoring_events
    await logExecutionEvent(
      supabase,
      positionId,
      'closed',
      exitPrice,
      `Position closed at $${exitPrice} | Mode: ${exitType}`
    )

    return {
      success: true,
      execution_type: exitType.includes('simulated') ? 'simulated' : 'live',
      message: `Position closed at $${exitPrice}`
    }
  } catch (error) {
    console.error('[Position Executor] Exit error:', error)
    return {
      success: false,
      execution_type: 'simulated',
      message: 'Exit failed: ' + (error instanceof Error ? error.message : 'Unknown error')
    }
  }
}
