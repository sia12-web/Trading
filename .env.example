# OANDA API Configuration
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ENVIRONMENT=practice  # practice or live
# When true (default), open/close routes place real OANDA orders
OANDA_EXECUTE_ORDERS=true

# Supabase Configuration (PUBLIC - can be in frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Railway-safe runtime aliases (server reads these if NEXT_PUBLIC was empty at build)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (SERVER-SIDE ONLY - NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database Configuration (for migrations if needed)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Claude / multi-LLM (Level Finder)
ANTHROPIC_API_KEY=your_claude_api_key_here
# Optional Gemini Flash verifier (KEEP/DROP only — never invents levels)
# GEMINI_API_KEY=your_gemini_api_key_here
# Live desk (morning auto-levels) — quality
# LLM_PROPOSER=anthropic
# LLM_PROPOSER_MODEL=claude-opus-4-20250514
# Simulation / replay — cheap (Haiku ~1/15th of Opus). Pass ?tier=sim or body.llm_tier=sim
# LLM_SIM_PROPOSER=anthropic
# LLM_SIM_PROPOSER_MODEL=claude-haiku-4-5-20251001
# Or use Gemini Flash for sim: LLM_SIM_PROPOSER=gemini + GEMINI_API_KEY
# LLM_VERIFIER=gemini
# LLM_VERIFIER_MODEL=gemini-2.0-flash
# LLM_VERIFIER=off   # code grounding only

# Finnhub (quotes + candles for chart desk)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Public site URL (optional; level archive is in-process and does not require this)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# Application Environment
NODE_ENV=production

# Logging (Railway): debug | info | warn | error — default info in production
LOG_LEVEL=info

# --- Production desk auth ---
# Personal single-trader deploy: set DESK_MODE=single (uses DESK_USER_ID below).
# Prefer real Supabase Auth sessions when possible.
DESK_MODE=single
DESK_USER_ID=00000000-0000-0000-0000-000000000001
# Optional shared secret for automation (Authorization: Bearer … or x-desk-secret)
# DESK_SECRET=long-random-string

# Required in production for cron routes (market-open, auto-levels, morning-review)
# Cron Authorization header: Bearer <CRON_SECRET>
CRON_SECRET=long-random-cron-secret

# NEVER set ALLOW_DEV_AUTH=true in a public production deploy
# ALLOW_DEV_AUTH=false

# After Railway gives you a domain, set this to that URL (no trailing slash)
# NEXT_PUBLIC_BASE_URL=https://your-app.up.railway.app
